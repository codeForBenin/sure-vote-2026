{% extends 'base.html.twig' %}

{% block title %}{{ title }} - Administration{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 flex flex-col">
    <!-- Header simple -->
    <header class="bg-benin-green text-white py-6 px-8 shadow-md">
        <div class="max-w-5xl mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-black tracking-tight">SURE<span class="text-benin-yellow">VOTE</span> <span class="text-white text-lg font-medium ml-2">Administration</span></h1>
            <a href="{{ path('admin') }}" class="text-sm font-bold bg-white/10 hover:bg-white/20 px-4 py-2 rounded-lg transition-colors">
                &larr; Retour au Dashboard
            </a>
        </div>
    </header>

    <main class="flex-grow flex items-center justify-center p-6">
        <div class="w-full max-w-2xl bg-white rounded-[2rem] shadow-xl border border-slate-100 p-10">
            <div class="text-center mb-10">
                <div class="inline-flex items-center justify-center h-20 w-20 rounded-3xl bg-blue-50 text-blue-600 mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                </div>
                <h2 class="text-3xl font-black text-slate-900 mb-3">{{ title }}</h2>
                <p class="text-slate-500 mb-2">Uploadez un fichier (CSV, XLSX ou ODS) contenant la liste des centres de vote.</p>
                
                <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 text-left text-xs text-slate-600 space-y-2 font-mono">
                    <div class="font-bold text-slate-800 border-b border-slate-200 pb-2 mb-2">Structure des colonnes :</div>
                    <div>1. Nom du Centre (ex: "EPP Gbégamey")</div>
                    <div>2. Code Unique (ex: "C15-01") <span class="bg-red-100 text-red-800 px-1 rounded">Requis</span></div>
                    <div>3. Code Circonscription (ex: "C15") <span class="bg-red-100 text-red-800 px-1 rounded">Requis</span></div>
                    <div>4. Adresse (Optionnel)</div>
                    <div>5. Latitude (Optionnel)</div>
                    <div>6. Longitude (Optionnel)</div>
                </div>
            </div>

            {{ form_start(form, {
                'attr': {
                    'id': 'import-form',
                    'enctype': 'multipart/form-data',
                    'data-turbo': 'false',
                    'data-controller': 'import',
                    'data-action': 'submit->import#submit'
                }
            }) }}
                <div class="space-y-6">
                    <div>
                        {{ form_label(form.file, null, {'label_attr': {'class': 'block text-sm font-bold text-slate-700 mb-2'}}) }}
                        {{ form_widget(form.file, {'attr': {'class': 'block w-full text-sm text-slate-500
                            file:mr-4 file:py-3 file:px-6
                            file:rounded-full file:border-0
                            file:text-sm file:font-semibold
                            file:bg-blue-50 file:text-blue-700
                            hover:file:bg-blue-100
                            cursor-pointer border border-slate-200 rounded-xl bg-slate-50'}}) }}
                        {{ form_errors(form.file) }}
                        <div class="text-xs text-slate-400 mt-2 ml-1">Formats acceptés : CSV, Excel, ODS. Max 5Mo.</div>
                    </div>

                    <button type="submit" 
                            data-import-target="button"
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-600/20 transition-all hover:scale-[1.01] flex items-center justify-center gap-3">
                        <span data-import-target="text">Importer les Centres</span>
                        <svg data-import-target="spinner" class="animate-spin h-5 w-5 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </button>
                    {{ form_row(form._token) }}
                </div>
            {{ form_end(form) }}
        </div>
    </main>
</div>
{% endblock %}
